        <mxPoint x="360" y="400" as="sourcePoint" />
        <mxPoint x="110" y="400" as="targetPoint" />
      </mxGeometry>
    </mxCell>
    <mxCell id="n1" value="The real secret key is returned only once. The database keeps only hashedKey." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;fillColor=#FEF3C7;strokeColor=#D97706;fontColor=#111827;fontSize=11;" vertex="1" parent="1">
