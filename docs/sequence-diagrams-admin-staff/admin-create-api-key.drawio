    <mxCell id="m1" value="1. Enter label + scopes" style="edgeStyle=none;rounded=0;html=1;strokeColor=#111827;endArrow=block;endFill=1;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="110" y="150" as="sourcePoint" />
        <mxPoint x="360" y="150" as="targetPoint" />
      </mxGeometry>
    </mxCell>
    <mxCell id="m2" value="2. POST /admin/api-keys" style="edgeStyle=none;rounded=0;html=1;strokeColor=#111827;endArrow=block;endFill=1;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="360" y="190" as="sourcePoint" />
        <mxPoint x="650" y="190" as="targetPoint" />
      </mxGeometry>
    </mxCell>
    <mxCell id="m3" value="3. Generate plain key + hashed key" style="edgeStyle=none;rounded=0;html=1;strokeColor=#111827;endArrow=block;endFill=1;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="650" y="240" as="sourcePoint" />
        <mxPoint x="650" y="240" as="targetPoint" />
      </mxGeometry>
    </mxCell>
    <mxCell id="m4" value="4. Store hashed key" style="edgeStyle=none;rounded=0;html=1;strokeColor=#111827;endArrow=block;endFill=1;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="650" y="280" as="sourcePoint" />
        <mxPoint x="980" y="280" as="targetPoint" />
      </mxGeometry>
    </mxCell>
    <mxCell id="m5" value="5. Saved key metadata" style="edgeStyle=none;rounded=0;html=1;strokeColor=#111827;dashed=1;dashPattern=4 4;endArrow=block;endFill=0;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="980" y="320" as="sourcePoint" />
        <mxPoint x="650" y="320" as="targetPoint" />
      </mxGeometry>
    </mxCell>
    <mxCell id="m6" value="6. Return key once" style="edgeStyle=none;rounded=0;html=1;strokeColor=#111827;dashed=1;dashPattern=4 4;endArrow=block;endFill=0;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="650" y="360" as="sourcePoint" />
        <mxPoint x="360" y="360" as="targetPoint" />
      </mxGeometry>
    </mxCell>
    <mxCell id="m7" value="7. Show/copy API key" style="edgeStyle=none;rounded=0;html=1;strokeColor=#111827;dashed=1;dashPattern=4 4;endArrow=block;endFill=0;fontSize=11;labelBackgroundColor=#FFFFFF;" edge="1" parent="1">
